<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PM2E124580053.Views.MapaPage"
             Title="Ubicación"
			 BackgroundColor="#F7F8FA">

    <VerticalStackLayout Padding="20" Spacing="16">

        <Label Text="Ubicación del Sitio"
			   FontSize="24"
			   FontAttributes="Bold"
			   TextColor="#1A1D23"
			   HorizontalOptions="Start"
			   Margin="0,0,0,4"/>

        <Border Stroke="#E4E7EC" StrokeThickness="1" BackgroundColor="#FFFFFF">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="4" Padding="16">
                <Label Text="DESCRIPCIÓN"
					   FontSize="11"
					   FontAttributes="Bold"
					   TextColor="#8A919E"
					   CharacterSpacing="1.5"/>
                <Label x:Name="lblDescripcion"
					   TextColor="#1A1D23"
					   FontSize="15"
					   Margin="0,0,0,12"/>
                <Label Text="COORDENADAS"
					   FontSize="11"
					   FontAttributes="Bold"
					   TextColor="#8A919E"
					   CharacterSpacing="1.5"/>
                <Label x:Name="lblCoordenadas"
					   TextColor="#1A1D23"
					   FontSize="14"/>
            </VerticalStackLayout>
        </Border>

        <Button Text="Ver en Google Maps"
		  Clicked="OnVerMapaClicked"
		  BackgroundColor="#3B5BDB"
		  TextColor="White"
		  CornerRadius="12"
		  FontAttributes="Bold"
		  HeightRequest="48"/>

        <Button Text="Compartir Imagen"
		 Clicked="OnCompartirClicked"
		 BackgroundColor="#FFFFFF"
		 TextColor="#3B5BDB"
		 BorderColor="#D0D7E6"
		 BorderWidth="1"
		 CornerRadius="12"
		 FontAttributes="Bold"
		 HeightRequest="48"/>

    </VerticalStackLayout>
</ContentPage>